# ============================================
# Trader Dashboard V5 — Environment Variables
# ============================================
# Copy this file to `.env` and modify as needed.
# All variables are OPTIONAL — defaults work out of the box.

# --- Cache Settings ---
# How long cached data stays fresh (in seconds). Default: 900 (15 min)
# CACHE_EXPIRY_SECONDS=900

# Days before forcing a full data re-download. Default: 7
# FULL_REFRESH_DAYS=7

# --- Risk Calculation ---
# Annual risk-free rate for Sharpe/Sortino calculations. Default: 0.04 (4%)
# RISK_FREE_RATE=0.04

# --- FRED API (Optional) ---
# Providing a FRED API key improves data reliability.
# Get one for free at: https://fred.stlouisfed.org/docs/api/api_key.html
# FRED_API_KEY=your_api_key_here
